<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BasketballScout.App.ViewModels"
             x:Class="BasketballScout.App.Views.SeasonOverviewPage"
             x:DataType="vm:SeasonOverviewViewModel"
             Title="Seasons">

    <Grid RowDefinitions="Auto,*" Padding="16">
        <Label Text="BasketballScout"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,0,0,16" />

        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Seasons}"
                        EmptyView="No seasons yet. Tap + to create one.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Padding="12" Margin="0,4"
                            BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1a1a1a}"
                            StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding .}" FontSize="16" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
