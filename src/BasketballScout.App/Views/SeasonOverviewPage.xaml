<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BasketballScout.App.ViewModels"
             xmlns:models="clr-namespace:BasketballScout.Core.Models;assembly=BasketballScout.Core"
             x:Class="BasketballScout.App.Views.SeasonOverviewPage"
             x:DataType="vm:SeasonOverviewViewModel"
             Title="Seasons">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="About"
                     Command="{Binding ShowAboutCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*" Padding="16">
        <Grid ColumnDefinitions="*,Auto">
            <Label Text="Basketball Scout"
                   FontSize="24"
                   FontAttributes="Bold"
                   VerticalOptions="Center" />
            <Button Grid.Column="1"
                    Text="+ Season"
                    Command="{Binding AddSeasonCommand}"
                    BackgroundColor="#e85d26"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="16,8" />
        </Grid>

        <!-- Backup / restore (US-26) -->
        <VerticalStackLayout Grid.Row="1" Spacing="8" Margin="0,12,0,0">
            <Border IsVisible="{Binding BackupReminderVisible}"
                    BackgroundColor="{AppThemeBinding Light=#fff7e6, Dark=#2a1f0a}"
                    Stroke="{AppThemeBinding Light=#f0d090, Dark=#3a2a10}"
                    StrokeShape="RoundRectangle 8" Padding="12,8">
                <Label Text="⚠ It's been a while since your last backup. Tap 'Back up all data' to keep your seasons safe."
                       FontSize="12" TextColor="{AppThemeBinding Light=#8a6d1a, Dark=#fbbf24}" />
            </Border>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="⤴ Back up all data"
                        Command="{Binding BackupAllCommand}"
                        BackgroundColor="#13251a" TextColor="#34d399"
                        FontAttributes="Bold" CornerRadius="8" FontSize="13" HeightRequest="42" />
                <Button Grid.Column="1" Text="⤵ Restore"
                        Command="{Binding RestoreAllCommand}"
                        BackgroundColor="{AppThemeBinding Light=#f0f0f0, Dark=#1a1a1a}"
                        TextColor="{AppThemeBinding Light=#333, Dark=#ccc}"
                        FontAttributes="Bold" CornerRadius="8" FontSize="13" HeightRequest="42" />
            </Grid>
        </VerticalStackLayout>

        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Seasons}"
                        Margin="0,16,0,0"
                        EmptyView="No seasons yet. Tap '+ Season' to create one.">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Season">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Delete"
                                           BackgroundColor="#f87171"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeasonOverviewViewModel}}, Path=DeleteSeasonCommand}"
                                           CommandParameter="{Binding .}" />
                            </SwipeItems>
                        </SwipeView.RightItems>
                        <Border Padding="16" Margin="0,4"
                                BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1a1a1a}"
                                StrokeShape="RoundRectangle 8"
                                Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeasonOverviewViewModel}}, Path=SelectSeasonCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Grid.Row="1"
                                       Text="{Binding StartDate, StringFormat='{0:MMM yyyy}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=#666, Dark=#999}" />
                                <Label Grid.Column="1"
                                       Grid.RowSpan="2"
                                       Text=">"
                                       FontSize="20"
                                       TextColor="{AppThemeBinding Light=#999, Dark=#555}"
                                       VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>
