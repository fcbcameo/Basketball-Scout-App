<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BasketballScout.App.ViewModels"
             xmlns:svc="clr-namespace:BasketballScout.Services;assembly=BasketballScout.Services"
             x:Class="BasketballScout.App.Views.GameBoxScorePage"
             x:DataType="vm:GameBoxScoreViewModel"
             Title="Box Score"
             BackgroundColor="#0a0a0a">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="12">

            <!-- Action buttons -->
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Button Text="Share Game Report PDF"
                            Command="{Binding SharePdfCommand}"
                            BackgroundColor="#e85d26"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="42" />
                    <Button Grid.Column="1" Text="✎ Edit Stats"
                            Command="{Binding EditStatsCommand}"
                            BackgroundColor="#1a2336"
                            TextColor="#60a5fa"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="42"
                            Padding="14,0" />
                </Grid>
                <!-- US-14: export this game as a self-contained JSON bundle -->
                <Button Text="⤴ Export Game (JSON)"
                        Command="{Binding ExportGameCommand}"
                        BackgroundColor="#13251a"
                        TextColor="#34d399"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        HeightRequest="42" />
            </VerticalStackLayout>

            <!-- Scoreboard Header -->
            <Border Padding="16" BackgroundColor="#0e0e0e" StrokeShape="RoundRectangle 10"
                    Stroke="#1a1a1a">
                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                    <Label Text="{Binding ScoreDisplay}" FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" />
                    <Label Text="{Binding GameDateDisplay}" FontSize="12" TextColor="#666"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- Home Team Box Score -->
            <Border Padding="12" BackgroundColor="#0e0e0e" StrokeShape="RoundRectangle 10"
                    Stroke="#1a1a1a">
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding HomeTeamName}" FontSize="14" FontAttributes="Bold"
                           TextColor="White" />

                    <!-- Header -->
                    <Grid ColumnDefinitions="25,*,30,40,40,30,28,28,28,25,30"
                          Padding="4,4" BackgroundColor="#141414">
                        <Label Text="#" FontSize="8" TextColor="#555" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="PLAYER" FontSize="8" TextColor="#555" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="PTS" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="3" Text="FG" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="4" Text="3PT" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="5" Text="FT" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="6" Text="REB" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="7" Text="AST" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="8" Text="STL" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="9" Text="BLK" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="10" Text="TO" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding HomeLines}" Spacing="0">
                        <BindableLayout.EmptyView>
                            <Label Text="No stats" FontSize="11" TextColor="#444"
                                   HorizontalOptions="Center" Margin="0,8" />
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="svc:PlayerBoxLine">
                                <Grid ColumnDefinitions="25,*,30,40,40,30,28,28,28,25,30"
                                      Padding="4,5">
                                    <Label Text="{Binding JerseyNumber}" FontSize="10" TextColor="#666" FontAttributes="Bold" />
                                    <Label Grid.Column="1" Text="{Binding PlayerName}" FontSize="10" TextColor="#ccc"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="2" Text="{Binding Points}" FontSize="11" FontAttributes="Bold"
                                           TextColor="White" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="3" Text="{Binding FgDisplay}" FontSize="9"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="4" Text="{Binding Fg3Display}" FontSize="9"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="5" Text="{Binding FtDisplay}" FontSize="9"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="6" Text="{Binding Rebounds}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="7" Text="{Binding Assists}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="8" Text="{Binding Steals}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="9" Text="{Binding Blocks}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="10" Text="{Binding Turnovers}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Away Team Box Score -->
            <Border Padding="12" BackgroundColor="#0e0e0e" StrokeShape="RoundRectangle 10"
                    Stroke="#1a1a1a">
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding AwayTeamName}" FontSize="14" FontAttributes="Bold"
                           TextColor="White" />

                    <!-- Header -->
                    <Grid ColumnDefinitions="25,*,30,40,40,30,28,28,28,25,30"
                          Padding="4,4" BackgroundColor="#141414">
                        <Label Text="#" FontSize="8" TextColor="#555" FontAttributes="Bold" />
                        <Label Grid.Column="1" Text="PLAYER" FontSize="8" TextColor="#555" FontAttributes="Bold" />
                        <Label Grid.Column="2" Text="PTS" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="3" Text="FG" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="4" Text="3PT" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="5" Text="FT" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="6" Text="REB" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="7" Text="AST" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="8" Text="STL" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="9" Text="BLK" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Grid.Column="10" Text="TO" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                    </Grid>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding AwayLines}" Spacing="0">
                        <BindableLayout.EmptyView>
                            <Label Text="No stats" FontSize="11" TextColor="#444"
                                   HorizontalOptions="Center" Margin="0,8" />
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="svc:PlayerBoxLine">
                                <Grid ColumnDefinitions="25,*,30,40,40,30,28,28,28,25,30"
                                      Padding="4,5">
                                    <Label Text="{Binding JerseyNumber}" FontSize="10" TextColor="#666" FontAttributes="Bold" />
                                    <Label Grid.Column="1" Text="{Binding PlayerName}" FontSize="10" TextColor="#ccc"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Column="2" Text="{Binding Points}" FontSize="11" FontAttributes="Bold"
                                           TextColor="White" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="3" Text="{Binding FgDisplay}" FontSize="9"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="4" Text="{Binding Fg3Display}" FontSize="9"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="5" Text="{Binding FtDisplay}" FontSize="9"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="6" Text="{Binding Rebounds}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="7" Text="{Binding Assists}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="8" Text="{Binding Steals}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="9" Text="{Binding Blocks}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="10" Text="{Binding Turnovers}" FontSize="10"
                                           TextColor="#aaa" HorizontalTextAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Shooting by zone (US-23) -->
            <Border Padding="12" BackgroundColor="#0e0e0e" StrokeShape="RoundRectangle 10"
                    Stroke="#1a1a1a">
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Label Text="SHOOTING BY ZONE" FontSize="10" FontAttributes="Bold"
                               TextColor="#555" CharacterSpacing="2" VerticalOptions="Center" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="cold" FontSize="8" TextColor="#666" VerticalOptions="Center" />
                            <BoxView WidthRequest="12" HeightRequest="8" Color="#3b82f6" VerticalOptions="Center" />
                            <BoxView WidthRequest="12" HeightRequest="8" Color="#fbbf24" VerticalOptions="Center" />
                            <BoxView WidthRequest="12" HeightRequest="8" Color="#ef4444" VerticalOptions="Center" />
                            <Label Text="hot" FontSize="8" TextColor="#666" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Picker Grid.Column="2" ItemsSource="{Binding ZonePeriods}"
                                SelectedItem="{Binding SelectedZonePeriod}"
                                TextColor="#ccc" FontSize="12" BackgroundColor="#141414"
                                MinimumWidthRequest="80" />
                    </Grid>

                    <Label Text="{Binding HomeTeamName}" FontSize="12" FontAttributes="Bold" TextColor="White" />
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" Direction="Row"
                                BindableLayout.ItemsSource="{Binding HomeZones}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="svc:ZoneStat">
                                <Border WidthRequest="92" Padding="6,5" Margin="0,0,6,6"
                                        StrokeShape="RoundRectangle 6" Stroke="#222"
                                        BackgroundColor="{Binding HeatColor}">
                                    <VerticalStackLayout Spacing="1">
                                        <Label Text="{Binding Label}" FontSize="8" FontAttributes="Bold" TextColor="White" />
                                        <Label Text="{Binding Display}" FontSize="12" FontAttributes="Bold" TextColor="White" />
                                        <Label Text="{Binding PctDisplay}" FontSize="9" TextColor="#f5f5f5" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <Label Text="{Binding AwayTeamName}" FontSize="12" FontAttributes="Bold" TextColor="White" Margin="0,4,0,0" />
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" Direction="Row"
                                BindableLayout.ItemsSource="{Binding AwayZones}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="svc:ZoneStat">
                                <Border WidthRequest="92" Padding="6,5" Margin="0,0,6,6"
                                        StrokeShape="RoundRectangle 6" Stroke="#222"
                                        BackgroundColor="{Binding HeatColor}">
                                    <VerticalStackLayout Spacing="1">
                                        <Label Text="{Binding Label}" FontSize="8" FontAttributes="Bold" TextColor="White" />
                                        <Label Text="{Binding Display}" FontSize="12" FontAttributes="Bold" TextColor="White" />
                                        <Label Text="{Binding PctDisplay}" FontSize="9" TextColor="#f5f5f5" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
