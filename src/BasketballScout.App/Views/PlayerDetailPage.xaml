<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BasketballScout.App.ViewModels"
             xmlns:enums="clr-namespace:BasketballScout.Core.Enums;assembly=BasketballScout.Core"
             x:Class="BasketballScout.App.Views.PlayerDetailPage"
             x:DataType="vm:PlayerDetailViewModel"
             Title="{Binding Name, StringFormat='Player: {0}', FallbackValue='New Player'}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Border Padding="16"
                    BackgroundColor="{AppThemeBinding Light=#f5f5f5, Dark=#1a1a1a}"
                    StrokeShape="RoundRectangle 8"
                    Stroke="{AppThemeBinding Light=#e0e0e0, Dark=#333}">
                <VerticalStackLayout Spacing="16">
                    <Label Text="Player Details" FontSize="18" FontAttributes="Bold" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Name" FontSize="13" TextColor="{AppThemeBinding Light=#666, Dark=#999}" />
                        <Entry Text="{Binding Name}"
                               Placeholder="e.g. De Smet"
                               FontSize="16" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Jersey Number" FontSize="13" TextColor="{AppThemeBinding Light=#666, Dark=#999}" />
                        <Entry Text="{Binding JerseyNumber}"
                               Placeholder="e.g. 23"
                               Keyboard="Numeric"
                               FontSize="16" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="Position" FontSize="13" TextColor="{AppThemeBinding Light=#666, Dark=#999}" />
                        <Picker ItemsSource="{Binding PositionOptions}"
                                SelectedItem="{Binding SelectedPosition}"
                                FontSize="16" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Switch IsToggled="{Binding IsActive}" OnColor="#4ade80" />
                        <Label Grid.Column="1"
                               Text="{Binding IsActive, StringFormat='Active: {0}'}"
                               FontSize="14"
                               VerticalOptions="Center" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Text="Cancel"
                                Command="{Binding CancelCommand}"
                                BackgroundColor="{AppThemeBinding Light=#e0e0e0, Dark=#333}"
                                TextColor="{AppThemeBinding Light=#333, Dark=#ccc}"
                                CornerRadius="8" />
                        <Button Grid.Column="1"
                                Text="Save Player"
                                Command="{Binding SaveCommand}"
                                BackgroundColor="#e85d26"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="8" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
