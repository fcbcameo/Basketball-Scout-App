<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BasketballScout.App.ViewModels"
             xmlns:models="clr-namespace:BasketballScout.Core.Models;assembly=BasketballScout.Core"
             xmlns:views="clr-namespace:BasketballScout.App.Views"
             x:Class="BasketballScout.App.Views.GameScoringPage"
             x:DataType="vm:GameScoringViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0a0a0a">

    <Grid RowDefinitions="50,*" BackgroundColor="#0a0a0a">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 0: SCOREBOARD BAR                           -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid BackgroundColor="#0e0e0e" Padding="16,0" ColumnDefinitions="*,Auto,*">
            <Border StrokeShape="RoundRectangle 6" Stroke="Transparent"
                    BackgroundColor="#0e0e0e" Padding="12,2"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="{Binding HomeTeamAbbr}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding HomeTeamColor}" VerticalOptions="Center" />
                    <Label Text="{Binding HomeScore}" FontSize="24" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center" />
                    <Label Text="{Binding HomeFouls, StringFormat='F:{0}'}" FontSize="10"
                           TextColor="#9a9a9a" VerticalOptions="Center" />
                    <Label Text="BONUS" FontSize="8" FontAttributes="Bold" TextColor="#fbbf24"
                           CharacterSpacing="1" VerticalOptions="Center"
                           IsVisible="{Binding HomeInBonus}" />
                </HorizontalStackLayout>
            </Border>

            <!-- Center: Clock + Buttons -->
            <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Center">
                <!-- Leave (resume later) — distinct from END which finishes the game (US-16) -->
                <Button Text="← LEAVE" Command="{Binding LeaveGameCommand}"
                        FontSize="13" FontAttributes="Bold" Padding="14,4"
                        BackgroundColor="#1a1a1a" TextColor="#888" CornerRadius="4"
                        HeightRequest="36" MinimumHeightRequest="36" MinimumWidthRequest="64" />
                <Label Text="{Binding PeriodLabel}" FontSize="11" FontAttributes="Bold"
                       TextColor="#888" VerticalOptions="Center" CharacterSpacing="2" />
                <!-- Scoring run flag (US-25) -->
                <Border IsVisible="{Binding HasScoringRun}" Padding="6,2" VerticalOptions="Center"
                        StrokeShape="RoundRectangle 4" Stroke="Transparent" BackgroundColor="#2a1f0a">
                    <Label Text="{Binding ScoringRunText}" FontSize="10" FontAttributes="Bold"
                           TextColor="{Binding ScoringRunColor}" CharacterSpacing="1" />
                </Border>
                <Border StrokeShape="RoundRectangle 4" Stroke="#1a1a1a" StrokeThickness="1"
                        BackgroundColor="#141414" Padding="8,2" VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleClockCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="{Binding GameClock}" FontSize="17" FontAttributes="Bold"
                           TextColor="{Binding ClockColor}" VerticalOptions="Center" />
                </Border>
                <Button Text="Q+" Command="{Binding NextQuarterCommand}"
                        FontSize="12" FontAttributes="Bold" Padding="12,4"
                        BackgroundColor="#1a1a1a" TextColor="#888" CornerRadius="4"
                        HeightRequest="36" MinimumHeightRequest="36" MinimumWidthRequest="44" />
                <Button Text="↶ UNDO" Command="{Binding UndoCommand}"
                        FontSize="13" FontAttributes="Bold" Padding="14,4"
                        BackgroundColor="#3a1a1a" TextColor="#f87171" CornerRadius="4"
                        HeightRequest="36" MinimumHeightRequest="36" MinimumWidthRequest="64" />
                <Button Text="✎ FIX" Command="{Binding ToggleCorrectionsCommand}"
                        FontSize="13" FontAttributes="Bold" Padding="14,4"
                        BackgroundColor="#1a2336" TextColor="#60a5fa" CornerRadius="4"
                        HeightRequest="36" MinimumHeightRequest="36" MinimumWidthRequest="56" />
                <Button Text="✓ END" Command="{Binding FinishGameCommand}"
                        FontSize="13" FontAttributes="Bold" Padding="14,4"
                        BackgroundColor="#13301d" TextColor="#4ade80" CornerRadius="4"
                        HeightRequest="36" MinimumHeightRequest="36" MinimumWidthRequest="56" />
            </HorizontalStackLayout>

            <!-- Away Score -->
            <Border Grid.Column="2" StrokeShape="RoundRectangle 6" Stroke="Transparent"
                    BackgroundColor="#0e0e0e" Padding="12,2"
                    HorizontalOptions="Center" VerticalOptions="Center">
                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="BONUS" FontSize="8" FontAttributes="Bold" TextColor="#fbbf24"
                           CharacterSpacing="1" VerticalOptions="Center"
                           IsVisible="{Binding AwayInBonus}" />
                    <Label Text="{Binding AwayFouls, StringFormat='F:{0}'}" FontSize="10"
                           TextColor="#9a9a9a" VerticalOptions="Center" />
                    <Label Text="{Binding AwayScore}" FontSize="24" FontAttributes="Bold"
                           TextColor="White" VerticalOptions="Center" />
                    <Label Text="{Binding AwayTeamAbbr}" FontSize="11" FontAttributes="Bold"
                           TextColor="{Binding AwayTeamColor}" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ROW 1: 3-COLUMN LAYOUT                          -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="140,*,140">

            <!-- ─── LEFT: HOME TEAM ROSTER ─── -->
            <Grid BackgroundColor="#0c0c0c"
                  RowDefinitions="Auto,*">
                <Border StrokeShape="RoundRectangle 0" Stroke="Transparent"
                        BackgroundColor="#0c0c0c" Padding="8,6,8,4">
                    <Label Text="{Binding HomeTeamName}" FontSize="8" FontAttributes="Bold"
                           TextColor="{Binding HomeTeamColor}" CharacterSpacing="1.5"
                           TextTransform="Uppercase" />
                </Border>
                <ScrollView Grid.Row="1" Padding="4,0,4,4">
                    <VerticalStackLayout Spacing="0">
                        <!-- Home Active Players -->
                        <VerticalStackLayout x:Name="HomeOnCourtPanel" Spacing="0"
                                             BindableLayout.ItemsSource="{Binding HomeOnCourt}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:Player">
                                    <Border Padding="8,5" Margin="0,1.5"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="#1a1a1a" StrokeThickness="2"
                                            BackgroundColor="#141414">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=SelectPlayerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding JerseyNumber}" FontSize="{DynamicResource FsRosterNum}" FontAttributes="Bold"
                                                   TextColor="#bbb" VerticalOptions="Center" MinimumWidthRequest="30"
                                                   HorizontalTextAlignment="Center" />
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <Label Text="{Binding Name}" FontSize="{DynamicResource FsRosterName}" FontAttributes="Bold"
                                                       TextColor="#bbb" LineBreakMode="TailTruncation"
                                                       MaximumWidthRequest="75" />
                                                <Label Text="{Binding Position}" FontSize="8"
                                                       TextColor="#444" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="#1a1a1a" Margin="0,4" />
                        <Label Text="BENCH" FontSize="8" FontAttributes="Bold"
                               TextColor="#333" CharacterSpacing="1" Margin="4,0,0,2" />

                        <!-- Home Bench -->
                        <VerticalStackLayout x:Name="HomeBenchPanel" Spacing="0"
                                             BindableLayout.ItemsSource="{Binding HomeBench}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:Player">
                                    <Border Padding="8,5" Margin="0,1.5"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="#1a1a1a" StrokeThickness="2"
                                            BackgroundColor="#141414">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=SelectPlayerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="6">
                                            <Label Text="{Binding JerseyNumber}" FontSize="{DynamicResource FsRosterNum}" FontAttributes="Bold"
                                                   TextColor="#444" VerticalOptions="Center" MinimumWidthRequest="30"
                                                   HorizontalTextAlignment="Center" />
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <Label Text="{Binding Name}" FontSize="{DynamicResource FsRosterName}" FontAttributes="Bold"
                                                       TextColor="#555" LineBreakMode="TailTruncation"
                                                       MaximumWidthRequest="75" />
                                                <Label Text="{Binding Position}" FontSize="8"
                                                       TextColor="#333" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

            <!-- ─── CENTER: COURT + STAT BAR ─── -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto">

                <!-- Court area + popups layered -->
                <Grid>
                    <!-- Layer 1: Court drawing -->
                    <GraphicsView x:Name="CourtGraphicsView"
                                  BackgroundColor="#18150f"
                                  InputTransparent="True">
                        <GraphicsView.Drawable>
                            <views:CourtDrawable />
                        </GraphicsView.Drawable>
                    </GraphicsView>

                    <!-- Layer 2: Touch overlay for court taps + shot dots -->
                    <AbsoluteLayout x:Name="CourtOverlay" BackgroundColor="Transparent"
                                    InputTransparent="False">
                    </AbsoluteLayout>

                    <!-- Layer 3: Empty state hint -->
                    <VerticalStackLayout x:Name="CourtHint"
                                         HorizontalOptions="Center" VerticalOptions="Center"
                                         InputTransparent="True">
                        <Label Text="Select player, tap court" FontSize="10"
                               TextColor="#2a2520" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <!-- Layer 4: Shot Confirmation Popup -->
                    <Border x:Name="ShotConfirmPopup"
                            IsVisible="{Binding PendingShot, Converter={StaticResource NotNullToBoolConverter}}"
                            Padding="10" Margin="0,0,0,8"
                            BackgroundColor="#1a1714"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#e85d2655" StrokeThickness="1"
                            HorizontalOptions="Center" VerticalOptions="End"
                            WidthRequest="300"
                            ZIndex="10">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding SelectedPlayer.JerseyNumber, StringFormat='#{0}'}"
                                           FontSize="10" FontAttributes="Bold" TextColor="{Binding HomeTeamColor}" />
                                    <Label x:Name="ZoneLabel" FontSize="10" FontAttributes="Bold"
                                           TextColor="#60a5fa" Text="2PT ZONE" />
                                </HorizontalStackLayout>
                                <Label Grid.Column="1" Text="X" FontSize="13" TextColor="#444"
                                       HorizontalOptions="End">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnShotCancelClicked" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </Grid>
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="5">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="2PT" FontSize="8" FontAttributes="Bold"
                                           TextColor="#555" HorizontalOptions="Center" CharacterSpacing="1" />
                                    <Button Text="MADE" FontSize="16" FontAttributes="Bold"
                                            BackgroundColor="#4ade8018" TextColor="#4ade80"
                                            CornerRadius="6" Padding="0,16"
                                            BorderColor="#4ade8033" BorderWidth="1"
                                            Clicked="On2PtMadeClicked" />
                                    <Button Text="MISS" FontSize="16" FontAttributes="Bold"
                                            BackgroundColor="#f8717118" TextColor="#f87171"
                                            CornerRadius="6" Padding="0,16"
                                            BorderColor="#f8717133" BorderWidth="1"
                                            Clicked="On2PtMissClicked" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="3PT" FontSize="8" FontAttributes="Bold"
                                           TextColor="#555" HorizontalOptions="Center" CharacterSpacing="1" />
                                    <Button Text="MADE" FontSize="16" FontAttributes="Bold"
                                            BackgroundColor="#4ade8018" TextColor="#4ade80"
                                            CornerRadius="6" Padding="0,16"
                                            BorderColor="#4ade8033" BorderWidth="1"
                                            Clicked="On3PtMadeClicked" />
                                    <Button Text="MISS" FontSize="16" FontAttributes="Bold"
                                            BackgroundColor="#f8717118" TextColor="#f87171"
                                            CornerRadius="6" Padding="0,16"
                                            BorderColor="#f8717133" BorderWidth="1"
                                            Clicked="On3PtMissClicked" />
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Layer 5: Follow-Up Popup (assist / rebound) -->
                    <Border x:Name="FollowUpPopup"
                            IsVisible="{Binding FollowUp, Converter={StaticResource NotNullToBoolConverter}}"
                            Padding="10" Margin="0,0,0,8"
                            BackgroundColor="#121a12"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#4ade8033" StrokeThickness="1"
                            HorizontalOptions="Center" VerticalOptions="End"
                            WidthRequest="320"
                            ZIndex="11">
                        <VerticalStackLayout Spacing="6">
                            <Label x:Name="FollowUpLabel" Text="ASSISTED BY?"
                                   FontSize="9" FontAttributes="Bold" TextColor="#555"
                                   CharacterSpacing="1" />
                            <!-- HOME group: chips tinted with the home team color (US-13) -->
                            <VerticalStackLayout IsVisible="{Binding HasHomeFollowUpCandidates}" Spacing="3">
                                <Label Text="{Binding HomeTeamName}" FontSize="8" FontAttributes="Bold"
                                       TextColor="{Binding HomeTeamColor}" CharacterSpacing="1"
                                       TextTransform="Uppercase" />
                                <FlexLayout Wrap="Wrap" JustifyContent="Start" Direction="Row"
                                            BindableLayout.ItemsSource="{Binding HomeFollowUpCandidates}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FollowUpCandidate">
                                            <Button Text="{Binding Display}"
                                                    FontSize="16" FontAttributes="Bold"
                                                    BackgroundColor="{Binding ChipColor}" TextColor="White"
                                                    BorderColor="#00000055" BorderWidth="1"
                                                    CornerRadius="6" Padding="14,9"
                                                    Margin="0,0,4,4"
                                                    HeightRequest="46" MinimumHeightRequest="46" MinimumWidthRequest="52"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=HandleFollowUpCommand}"
                                                    CommandParameter="{Binding Player}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </VerticalStackLayout>

                            <!-- Divider between the two teams (only when both are shown) -->
                            <BoxView IsVisible="{Binding ShowFollowUpDivider}"
                                     HeightRequest="1" Color="#2a2a2a" Margin="0,2" />

                            <!-- AWAY group: chips tinted with the away team color (US-13) -->
                            <VerticalStackLayout IsVisible="{Binding HasAwayFollowUpCandidates}" Spacing="3">
                                <Label Text="{Binding AwayTeamName}" FontSize="8" FontAttributes="Bold"
                                       TextColor="{Binding AwayTeamColor}" CharacterSpacing="1"
                                       TextTransform="Uppercase" />
                                <FlexLayout Wrap="Wrap" JustifyContent="Start" Direction="Row"
                                            BindableLayout.ItemsSource="{Binding AwayFollowUpCandidates}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="vm:FollowUpCandidate">
                                            <Button Text="{Binding Display}"
                                                    FontSize="16" FontAttributes="Bold"
                                                    BackgroundColor="{Binding ChipColor}" TextColor="White"
                                                    BorderColor="#00000055" BorderWidth="1"
                                                    CornerRadius="6" Padding="14,9"
                                                    Margin="0,0,4,4"
                                                    HeightRequest="46" MinimumHeightRequest="46" MinimumWidthRequest="52"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=HandleFollowUpCommand}"
                                                    CommandParameter="{Binding Player}" />
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </VerticalStackLayout>
                            <Button Text="SKIP" FontSize="12" FontAttributes="Bold"
                                    BackgroundColor="#141414" TextColor="#666"
                                    CornerRadius="6" Padding="14,9"
                                    HeightRequest="40" MinimumHeightRequest="40"
                                    Command="{Binding SkipFollowUpCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Layer 6: Free-throw sequence after a foul (US-22) -->
                    <Border IsVisible="{Binding HasFtSequence}"
                            Padding="10" Margin="0,0,0,8"
                            BackgroundColor="#1a1a12"
                            StrokeShape="RoundRectangle 10"
                            Stroke="#fbbf2433" StrokeThickness="1"
                            HorizontalOptions="Center" VerticalOptions="End"
                            WidthRequest="300"
                            ZIndex="12">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding FtSequenceText}" FontSize="10" FontAttributes="Bold"
                                   TextColor="#fbbf24" CharacterSpacing="1" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="5">
                                <Button Text="✓ MADE" FontSize="16" FontAttributes="Bold"
                                        BackgroundColor="#4ade8018" TextColor="#4ade80"
                                        BorderColor="#4ade8033" BorderWidth="1"
                                        CornerRadius="6" Padding="0,14" HeightRequest="52" MinimumHeightRequest="52"
                                        Clicked="OnFtSeqMadeClicked" />
                                <Button Grid.Column="1" Text="✗ MISS" FontSize="16" FontAttributes="Bold"
                                        BackgroundColor="#f8717118" TextColor="#f87171"
                                        BorderColor="#f8717133" BorderWidth="1"
                                        CornerRadius="6" Padding="0,14" HeightRequest="52" MinimumHeightRequest="52"
                                        Clicked="OnFtSeqMissClicked" />
                            </Grid>
                            <Button Text="DONE" FontSize="12" FontAttributes="Bold"
                                    BackgroundColor="#141414" TextColor="#888"
                                    CornerRadius="6" Padding="14,9"
                                    HeightRequest="40" MinimumHeightRequest="40"
                                    Command="{Binding FtSequenceDoneCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- ── Quick Stat Bar ── -->
                <ScrollView Grid.Row="1" Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                            BackgroundColor="#0e0e0e" Padding="6,4">
                    <HorizontalStackLayout Spacing="5">
                        <!-- FT label -->
                        <Label Text="FT" FontSize="10" FontAttributes="Bold" TextColor="#555"
                               CharacterSpacing="1" VerticalOptions="Center" Margin="4,0" />
                        <Button Text="✓" FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#4ade8012" TextColor="#4ade80"
                                BorderColor="#4ade8022" BorderWidth="1"
                                CornerRadius="6" Padding="18,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnFTMadeClicked" />
                        <Button Text="✗" FontSize="16" FontAttributes="Bold"
                                BackgroundColor="#f8717112" TextColor="#f87171"
                                BorderColor="#f8717122" BorderWidth="1"
                                CornerRadius="6" Padding="18,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnFTMissClicked" />

                        <BoxView WidthRequest="1" HeightRequest="30" Color="#1a1a1a" VerticalOptions="Center" Margin="3,0" />

                        <Button Text="AST" FontSize="14" FontAttributes="Bold"
                                BackgroundColor="#141414" TextColor="#60a5fa"
                                BorderColor="#1e1e1e" BorderWidth="1"
                                CornerRadius="6" Padding="16,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnAstClicked" />
                        <Button Text="STL" FontSize="14" FontAttributes="Bold"
                                BackgroundColor="#141414" TextColor="#c084fc"
                                BorderColor="#1e1e1e" BorderWidth="1"
                                CornerRadius="6" Padding="16,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnStlClicked" />
                        <Button Text="BLK" FontSize="14" FontAttributes="Bold"
                                BackgroundColor="#141414" TextColor="#f472b6"
                                BorderColor="#1e1e1e" BorderWidth="1"
                                CornerRadius="6" Padding="16,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnBlkClicked" />
                        <Button Text="TO" FontSize="14" FontAttributes="Bold"
                                BackgroundColor="#141414" TextColor="#fb923c"
                                BorderColor="#1e1e1e" BorderWidth="1"
                                CornerRadius="6" Padding="16,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnToClicked" />

                        <BoxView WidthRequest="1" HeightRequest="30" Color="#1a1a1a" VerticalOptions="Center" Margin="3,0" />

                        <Button Text="O-RB" FontSize="12" FontAttributes="Bold"
                                BackgroundColor="#fbbf2410" TextColor="#fbbf24"
                                BorderColor="#fbbf2420" BorderWidth="1"
                                CornerRadius="6" Padding="14,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnOrebClicked" />
                        <Button Text="D-RB" FontSize="12" FontAttributes="Bold"
                                BackgroundColor="#60a5fa10" TextColor="#60a5fa"
                                BorderColor="#60a5fa20" BorderWidth="1"
                                CornerRadius="6" Padding="14,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnDrebClicked" />

                        <BoxView WidthRequest="1" HeightRequest="30" Color="#1a1a1a" VerticalOptions="Center" Margin="3,0" />

                        <Button Text="PF" FontSize="13" FontAttributes="Bold"
                                BackgroundColor="#fbbf2410" TextColor="#fbbf24"
                                BorderColor="#fbbf2420" BorderWidth="1"
                                CornerRadius="6" Padding="16,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnPfClicked" />
                        <Button Text="TF" FontSize="13" FontAttributes="Bold"
                                BackgroundColor="#f8717110" TextColor="#f87171"
                                BorderColor="#f8717120" BorderWidth="1"
                                CornerRadius="6" Padding="16,12" HeightRequest="48" MinimumHeightRequest="48"
                                Clicked="OnTechClicked" />
                    </HorizontalStackLayout>
                </ScrollView>
            </Grid>

            <!-- ─── RIGHT: AWAY TEAM ROSTER ─── -->
            <Grid Grid.Column="2" BackgroundColor="#0c0c0c"
                  RowDefinitions="Auto,*">
                <Border StrokeShape="RoundRectangle 0" Stroke="Transparent"
                        BackgroundColor="#0c0c0c" Padding="8,6,8,4">
                    <Label Text="{Binding AwayTeamName}" FontSize="8" FontAttributes="Bold"
                           TextColor="{Binding AwayTeamColor}" CharacterSpacing="1.5"
                           TextTransform="Uppercase" HorizontalTextAlignment="End" />
                </Border>
                <ScrollView Grid.Row="1" Padding="4,0,4,4">
                    <VerticalStackLayout Spacing="0">
                        <!-- Away Active Players -->
                        <VerticalStackLayout x:Name="AwayOnCourtPanel" Spacing="0"
                                             BindableLayout.ItemsSource="{Binding AwayOnCourt}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:Player">
                                    <Border Padding="8,5" Margin="0,1.5"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="#1a1a1a" StrokeThickness="2"
                                            BackgroundColor="#141414">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=SelectPlayerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="6" FlowDirection="RightToLeft">
                                            <Label Text="{Binding JerseyNumber}" FontSize="{DynamicResource FsRosterNum}" FontAttributes="Bold"
                                                   TextColor="#bbb" VerticalOptions="Center" MinimumWidthRequest="30"
                                                   HorizontalTextAlignment="Center" />
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <Label Text="{Binding Name}" FontSize="{DynamicResource FsRosterName}" FontAttributes="Bold"
                                                       TextColor="#bbb" LineBreakMode="TailTruncation"
                                                       MaximumWidthRequest="75" HorizontalTextAlignment="End" />
                                                <Label Text="{Binding Position}" FontSize="8"
                                                       TextColor="#444" HorizontalTextAlignment="End" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Divider -->
                        <BoxView HeightRequest="1" Color="#1a1a1a" Margin="0,4" />
                        <Label Text="BENCH" FontSize="8" FontAttributes="Bold"
                               TextColor="#333" CharacterSpacing="1" Margin="0,0,4,2"
                               HorizontalTextAlignment="End" />

                        <!-- Away Bench -->
                        <VerticalStackLayout x:Name="AwayBenchPanel" Spacing="0"
                                             BindableLayout.ItemsSource="{Binding AwayBench}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:Player">
                                    <Border Padding="8,5" Margin="0,1.5"
                                            StrokeShape="RoundRectangle 6"
                                            Stroke="#1a1a1a" StrokeThickness="2"
                                            BackgroundColor="#141414">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=SelectPlayerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout Spacing="6" FlowDirection="RightToLeft">
                                            <Label Text="{Binding JerseyNumber}" FontSize="{DynamicResource FsRosterNum}" FontAttributes="Bold"
                                                   TextColor="#444" VerticalOptions="Center" MinimumWidthRequest="30"
                                                   HorizontalTextAlignment="Center" />
                                            <VerticalStackLayout VerticalOptions="Center">
                                                <Label Text="{Binding Name}" FontSize="{DynamicResource FsRosterName}" FontAttributes="Bold"
                                                       TextColor="#555" LineBreakMode="TailTruncation"
                                                       MaximumWidthRequest="75" HorizontalTextAlignment="End" />
                                                <Label Text="{Binding Position}" FontSize="8"
                                                       TextColor="#333" HorizontalTextAlignment="End" />
                                            </VerticalStackLayout>
                                        </HorizontalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

        </Grid>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- CORRECTIONS DRAWER (US-5)                        -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsCorrectionsOpen}"
              BackgroundColor="#cc000000" ZIndex="100">
            <!-- Tap the backdrop to close -->
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseCorrectionsCommand}" />
            </Grid.GestureRecognizers>

            <Border BackgroundColor="#121212" StrokeShape="RoundRectangle 12"
                    Stroke="#262626" StrokeThickness="1"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    WidthRequest="540" MaximumHeightRequest="620" Margin="16">
                <!-- Swallow taps so tapping the panel doesn't close the drawer -->
                <Border.GestureRecognizers>
                    <TapGestureRecognizer />
                </Border.GestureRecognizers>

                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto" Padding="16,12" BackgroundColor="#161616">
                        <Label Text="CORRECTIONS" FontSize="13" FontAttributes="Bold"
                               TextColor="#ddd" CharacterSpacing="2" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="Done" Command="{Binding CloseCorrectionsCommand}"
                                FontSize="13" FontAttributes="Bold" Padding="18,6"
                                BackgroundColor="#1f2937" TextColor="#9ca3af" CornerRadius="6"
                                HeightRequest="38" MinimumHeightRequest="38" />
                    </Grid>

                    <ScrollView Grid.Row="1" Padding="16,8,16,16">
                        <VerticalStackLayout Spacing="6">

                            <!-- Adjust fouls -->
                            <Label Text="ADJUST FOULS (ON-COURT)" FontSize="10" FontAttributes="Bold"
                                   TextColor="#666" CharacterSpacing="1" Margin="0,4,0,2" />
                            <VerticalStackLayout Spacing="3"
                                                 BindableLayout.ItemsSource="{Binding FoulRows}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:PlayerFoulRow">
                                        <Border BackgroundColor="#181818" StrokeShape="RoundRectangle 6"
                                                Stroke="#222" StrokeThickness="1" Padding="10,5">
                                            <Grid ColumnDefinitions="*,Auto,44,Auto" ColumnSpacing="6">
                                                <Label Text="{Binding Label}" FontSize="13" FontAttributes="Bold"
                                                       TextColor="{Binding Color}" VerticalOptions="Center"
                                                       LineBreakMode="TailTruncation" />
                                                <Button Grid.Column="1" Text="−" FontSize="20" FontAttributes="Bold"
                                                        BackgroundColor="#2a1515" TextColor="#f87171" CornerRadius="6"
                                                        Padding="0" WidthRequest="44" HeightRequest="44"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=RemoveFoulCommand}"
                                                        CommandParameter="{Binding Player}" />
                                                <Label Grid.Column="2" Text="{Binding Fouls}" FontSize="17" FontAttributes="Bold"
                                                       TextColor="#eee" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                                <Button Grid.Column="3" Text="+" FontSize="20" FontAttributes="Bold"
                                                        BackgroundColor="#152a15" TextColor="#4ade80" CornerRadius="6"
                                                        Padding="0" WidthRequest="44" HeightRequest="44"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=AddFoulCommand}"
                                                        CommandParameter="{Binding Player}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <BoxView HeightRequest="1" Color="#222" Margin="0,8" />

                            <!-- Play-by-play (all events) -->
                            <Label Text="PLAY-BY-PLAY — ✕ DELETE · → FLIP MADE/MISS" FontSize="10" FontAttributes="Bold"
                                   TextColor="#666" CharacterSpacing="1" Margin="0,0,0,2" />
                            <VerticalStackLayout Spacing="3"
                                                 BindableLayout.ItemsSource="{Binding RecentEvents}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CorrectionEntry">
                                        <Border BackgroundColor="#181818" StrokeShape="RoundRectangle 6"
                                                Stroke="#222" StrokeThickness="1" Padding="10,5">
                                            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                                <Label Text="{Binding PlayerLabel}" FontSize="{DynamicResource FsPlayLog}" FontAttributes="Bold"
                                                       TextColor="{Binding Color}" VerticalOptions="Center"
                                                       MinimumWidthRequest="96" LineBreakMode="TailTruncation" />
                                                <Label Grid.Column="1" Text="{Binding Description}" FontSize="{DynamicResource FsPlayLog}"
                                                       TextColor="#ddd" VerticalOptions="Center" />
                                                <Label Grid.Column="2" Text="{Binding Meta}" FontSize="10"
                                                       TextColor="#555" VerticalOptions="Center" />
                                                <Button Grid.Column="3" Text="{Binding ToggleLabel}"
                                                        IsVisible="{Binding IsShot}"
                                                        FontSize="11" FontAttributes="Bold"
                                                        BackgroundColor="#1a2336" TextColor="#60a5fa" CornerRadius="6"
                                                        Padding="6,0" MinimumWidthRequest="66" HeightRequest="44"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=ToggleShotResultCommand}"
                                                        CommandParameter="{Binding .}" />
                                                <Button Grid.Column="4" Text="✕" FontSize="15" FontAttributes="Bold"
                                                        BackgroundColor="#2a1515" TextColor="#f87171" CornerRadius="6"
                                                        Padding="0" WidthRequest="44" HeightRequest="44"
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GameScoringViewModel}}, Path=DeleteEventCommand}"
                                                        CommandParameter="{Binding .}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
