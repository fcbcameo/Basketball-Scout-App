<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BasketballScout.App.ViewModels"
             xmlns:svc="clr-namespace:BasketballScout.Services;assembly=BasketballScout.Services"
             x:Class="BasketballScout.App.Views.SeasonStatsPage"
             x:DataType="vm:SeasonStatsViewModel"
             Title="Season Stats"
             BackgroundColor="#0a0a0a">

    <ScrollView>
        <VerticalStackLayout Padding="12" Spacing="12">

            <!-- Share PDF Button -->
            <Button Text="Share Season Report PDF"
                    Command="{Binding SharePdfCommand}"
                    BackgroundColor="#e85d26"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="42" />

            <!-- Games Section -->
            <Border Padding="12" BackgroundColor="#0e0e0e" StrokeShape="RoundRectangle 10"
                    Stroke="#1a1a1a">
                <VerticalStackLayout Spacing="8">
                    <Label Text="MATCHES" FontSize="10" FontAttributes="Bold"
                           TextColor="#555" CharacterSpacing="2" />

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Games}" Spacing="4">
                        <BindableLayout.EmptyView>
                            <VerticalStackLayout Spacing="2" Margin="0,10">
                                <Label Text="No matches played yet" FontSize="12" TextColor="#555"
                                       HorizontalOptions="Center" />
                                <Label Text="Completed matches will appear here" FontSize="10" TextColor="#3a3a3a"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </BindableLayout.EmptyView>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:GameSummary">
                                <Border Padding="10,8" StrokeShape="RoundRectangle 6"
                                        Stroke="#1a1a1a" BackgroundColor="#141414">
                                    <Grid ColumnDefinitions="78,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeasonStatsViewModel}}, Path=ViewGameCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="{Binding DateDisplay}" FontSize="10" TextColor="#666"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding ScoreDisplay}" FontSize="13"
                                               FontAttributes="Bold" TextColor="#ddd"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                        <Border Grid.Column="2" IsVisible="{Binding HasBadge}"
                                                StrokeShape="RoundRectangle 4" Stroke="Transparent"
                                                BackgroundColor="#1e1e1e" Padding="7,3"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding ResultBadge}" FontSize="11"
                                                   FontAttributes="Bold" TextColor="{Binding ResultColor}" />
                                        </Border>
                                        <Border Grid.Column="2" IsVisible="{Binding IsInProgress}"
                                                StrokeShape="RoundRectangle 4" Stroke="#3a2a10"
                                                BackgroundColor="#2a1f0a" Padding="7,3"
                                                VerticalOptions="Center">
                                            <Label Text="● RESUME" FontSize="10"
                                                   FontAttributes="Bold" TextColor="#fbbf24" />
                                        </Border>
                                        <Button Grid.Column="3"
                                                Text="PDF"
                                                IsVisible="{Binding ShowPdf}"
                                                FontSize="10"
                                                FontAttributes="Bold"
                                                BackgroundColor="#e85d26"
                                                TextColor="White"
                                                CornerRadius="4"
                                                Padding="8,4"
                                                HeightRequest="28"
                                                MinimumWidthRequest="48"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeasonStatsViewModel}}, Path=ShareGamePdfCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Button Grid.Column="4"
                                                Text="✕"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                BackgroundColor="#3a1a1a"
                                                TextColor="#f87171"
                                                CornerRadius="4"
                                                Padding="0"
                                                HeightRequest="28"
                                                MinimumWidthRequest="32"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeasonStatsViewModel}}, Path=DeleteGameCommand}"
                                                CommandParameter="{Binding .}" />
                                        <Label Grid.Column="5" Text=">" FontSize="14" TextColor="#444"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Stats Panel -->
            <Border Padding="12" BackgroundColor="#0e0e0e" StrokeShape="RoundRectangle 10"
                    Stroke="#1a1a1a">
                <VerticalStackLayout Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                        <Label Text="SEASON STATS" FontSize="10" FontAttributes="Bold"
                               TextColor="#555" CharacterSpacing="2" VerticalOptions="Center" />
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding TeamFilters}"
                                SelectedItem="{Binding SelectedTeamFilter}"
                                TextColor="#ccc"
                                FontSize="12"
                                BackgroundColor="#141414"
                                MinimumWidthRequest="120" />
                    </Grid>

                    <!-- Basic / Advanced toggle -->
                    <HorizontalStackLayout Spacing="8" Margin="0,0,0,6">
                        <Label Text="Advanced stats"
                               FontSize="12" TextColor="#aaa"
                               VerticalOptions="Center" />
                        <Switch IsToggled="{Binding ShowAdvanced}"
                                OnColor="#e85d26"
                                ThumbColor="White" />
                    </HorizontalStackLayout>

                    <!-- ─── BASIC VIEW ─── -->
                    <VerticalStackLayout IsVisible="{Binding ShowBasic}" Spacing="0">
                        <!-- Header -->
                        <Grid ColumnDefinitions="30,*,40,35,35,35,35,40,40,40"
                              Padding="4,4" BackgroundColor="#141414">
                            <Label Text="#" FontSize="8" TextColor="#555" FontAttributes="Bold" />
                            <Label Grid.Column="1" Text="PLAYER" FontSize="8" TextColor="#555" FontAttributes="Bold" />
                            <Label Grid.Column="2" Text="GP" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="PPG" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="RPG" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="APG" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="SPG" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="7" Text="FG%" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="8" Text="3P%" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="9" Text="FT%" FontSize="8" TextColor="#555" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Grid>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding PlayerStats}" Spacing="0">
                            <BindableLayout.EmptyView>
                                <Label Text="No stats recorded yet" FontSize="11" TextColor="#444"
                                       HorizontalOptions="Center" Margin="0,8" />
                            </BindableLayout.EmptyView>
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="svc:PlayerSeasonStats">
                                    <Border Padding="4,6" StrokeShape="RoundRectangle 0"
                                            Stroke="Transparent" BackgroundColor="#0e0e0e">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeasonStatsViewModel}}, Path=ViewPlayerCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="30,*,40,35,35,35,35,40,40,40">
                                            <Label Text="{Binding JerseyNumber}" FontSize="10" FontAttributes="Bold"
                                                   TextColor="#666" />
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label Text="{Binding PlayerName}" FontSize="10" TextColor="#ccc"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding TeamAbbr}" FontSize="7" TextColor="#555" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding GamesPlayed}" FontSize="10"
                                                   TextColor="#aaa" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="3" Text="{Binding Ppg}" FontSize="11" FontAttributes="Bold"
                                                   TextColor="White" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="4" Text="{Binding Rpg}" FontSize="10"
                                                   TextColor="#aaa" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="5" Text="{Binding Apg}" FontSize="10"
                                                   TextColor="#aaa" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="6" Text="{Binding Spg}" FontSize="10"
                                                   TextColor="#aaa" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="7" Text="{Binding FgPct, StringFormat='{0:F1}'}" FontSize="9"
                                                   TextColor="#aaa" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="8" Text="{Binding Fg3Pct, StringFormat='{0:F1}'}" FontSize="9"
                                                   TextColor="#aaa" HorizontalTextAlignment="Center" />
                                            <Label Grid.Column="9" Text="{Binding FtPct, StringFormat='{0:F1}'}" FontSize="9"
                                                   TextColor="#aaa" HorizontalTextAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <!-- ─── ADVANCED VIEW (horizontally scrollable wide table) ─── -->
                    <VerticalStackLayout IsVisible="{Binding ShowAdvanced}" Spacing="0">
                        <Label Text="Swipe to see more columns →" FontSize="9"
                               TextColor="#555" Margin="0,0,0,4" />
                        <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Always">
                            <VerticalStackLayout>
                                <!-- Header row -->
                                <Grid ColumnDefinitions="26,120,36,42,38,38,38,38,38,38,38,38,38,42,38,38,42,38,38,42,38,38,42,38,42,42,42,42,42,42,42,42"
                                      Padding="2,4" BackgroundColor="#141414">
                                    <Label Grid.Column="0"  Text="#"      FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="1"  Text="PLAYER" FontSize="8" FontAttributes="Bold" TextColor="#777" />
                                    <Label Grid.Column="2"  Text="GP"     FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="3"  Text="MPG"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="4"  Text="PPG"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="5"  Text="RPG"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="6"  Text="DRPG"   FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="7"  Text="ORPG"   FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="8"  Text="APG"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="9"  Text="SPG"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="10" Text="BPG"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="11" Text="TOV"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="12" Text="FG%"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="13" Text="FGM/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="14" Text="FGA/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="15" Text="2P%"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="16" Text="2PM/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="17" Text="2PA/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="18" Text="3P%"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="19" Text="3PM/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="20" Text="3PA/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="21" Text="FT%"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="22" Text="FTM/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="23" Text="FTA/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="24" Text="A/T"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="25" Text="eFG%"   FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="26" Text="TS%"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="27" Text="TSA/G"  FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="28" Text="EFF"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="29" Text="GmSc"   FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="30" Text="+/-"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                    <Label Grid.Column="31" Text="MIN"    FontSize="8" FontAttributes="Bold" TextColor="#777" HorizontalTextAlignment="Center" />
                                </Grid>

                                <!-- Data rows -->
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding PlayerStats}" Spacing="0">
                                    <BindableLayout.EmptyView>
                                        <Label Text="No stats recorded yet" FontSize="11" TextColor="#444"
                                               HorizontalOptions="Center" Margin="0,8" />
                                    </BindableLayout.EmptyView>
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="svc:PlayerSeasonStats">
                                            <Border Padding="2,4" StrokeShape="RoundRectangle 0"
                                                    Stroke="Transparent" BackgroundColor="#0e0e0e">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SeasonStatsViewModel}}, Path=ViewPlayerCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Border.GestureRecognizers>
                                                <Grid ColumnDefinitions="26,120,36,42,38,38,38,38,38,38,38,38,38,42,38,38,42,38,38,42,38,38,42,38,42,42,42,42,42,42,42,42">
                                                    <Label Grid.Column="0"  Text="{Binding JerseyNumber}" FontSize="9" TextColor="#666" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="1"  Text="{Binding PlayerName}" FontSize="9" TextColor="#ccc" LineBreakMode="TailTruncation" />
                                                    <Label Grid.Column="2"  Text="{Binding GamesPlayed}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="3"  Text="{Binding MpgDisplay}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="4"  Text="{Binding Ppg}" FontSize="10" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="5"  Text="{Binding Rpg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="6"  Text="{Binding Drpg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="7"  Text="{Binding Orpg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="8"  Text="{Binding Apg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="9"  Text="{Binding Spg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="10" Text="{Binding Bpg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="11" Text="{Binding Topg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="12" Text="{Binding FgPct, StringFormat='{0:F1}'}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="13" Text="{Binding FgmPg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="14" Text="{Binding FgaPg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="15" Text="{Binding Fg2Pct, StringFormat='{0:F1}'}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="16" Text="{Binding Fg2MPg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="17" Text="{Binding Fg2APg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="18" Text="{Binding Fg3Pct, StringFormat='{0:F1}'}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="19" Text="{Binding Fg3MPg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="20" Text="{Binding Fg3APg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="21" Text="{Binding FtPct, StringFormat='{0:F1}'}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="22" Text="{Binding FtmPg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="23" Text="{Binding FtaPg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="24" Text="{Binding AtDisplay}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="25" Text="{Binding EFgPct, StringFormat='{0:F1}'}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="26" Text="{Binding TsPct, StringFormat='{0:F1}'}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="27" Text="{Binding TsaPg}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="28" Text="{Binding EffDisplay}" FontSize="10" FontAttributes="Bold" TextColor="#e85d26" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="29" Text="{Binding GmScDisplay}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="30" Text="{Binding PlusMinusDisplay}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                    <Label Grid.Column="31" Text="{Binding TotalMinutesDisplay}" FontSize="9" TextColor="#aaa" HorizontalTextAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </ScrollView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
