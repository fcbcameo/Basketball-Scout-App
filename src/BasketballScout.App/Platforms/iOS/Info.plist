<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- Purpose strings required by App Store validation (error 90683):
	     the MAUI framework references these protected APIs even though
	     BasketballScout does not use them. -->
	<key>NSCalendarsUsageDescription</key>
	<string>BasketballScout does not access your calendar.</string>
	<key>NSContactsUsageDescription</key>
	<string>BasketballScout does not access your contacts.</string>
	<key>NSAppleMusicUsageDescription</key>
	<string>BasketballScout does not access your media library.</string>
	<key>NSSiriUsageDescription</key>
	<string>BasketballScout does not use Siri.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>BasketballScout does not use the microphone.</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UIDeviceFamily</key>
	<array>
		<integer>1</integer>
		<integer>2</integer>
	</array>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>
</dict>
</plist>
