<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BasketballScout.App"
             xmlns:converters="clr-namespace:BasketballScout.App.Converters"
             x:Class="BasketballScout.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:NotNullToBoolConverter x:Key="NotNullToBoolConverter" />
            <converters:BoolToColorConverter x:Key="MadeColorConverter" TrueColor="#4caf50" FalseColor="#f44336" />
            <converters:StringEqualConverter x:Key="StringEqualConverter" />

            <!-- Scalable font sizes for the scoring screen (US-30). TextSizeSettings.Apply
                 overwrites these at runtime for the Normal/Large setting. -->
            <x:Double x:Key="FsRosterNum">20</x:Double>
            <x:Double x:Key="FsRosterName">10</x:Double>
            <x:Double x:Key="FsPlayLog">12</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
